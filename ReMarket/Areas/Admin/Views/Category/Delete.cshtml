@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center my-3">
        <h2 class="fw-semibold">Delete Category</h2>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to List</a>
    </div>

    <partial name="_Notification" />

    <div class="card">
        <div class="card-body">
            <p class="text-danger mb-3">Are you sure you want to delete this category?</p>

            <div class="d-flex align-items-center gap-3 mb-4">
                @if (!string.IsNullOrEmpty(Model.IconImagePath))
                {
                    <img src="@Model.IconImagePath" alt="" class="rounded border" style="width:64px;height:64px;object-fit:cover" />
                }
                <div>
                    <div class="fw-semibold">@Model.Name</div>
                    <div class="small text-muted">Slug: <code>@Model.Slug</code></div>
                    <div class="small">@(Model.ParentCategoryId == null ? "Root category" : "Sub category")</div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <button type="submit" class="btn btn-danger btn-sm">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

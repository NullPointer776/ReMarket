@model List<Category>

@{
    ViewData["Title"] = "Category Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center my-3">
        <h2 class="fw-semibold">Category Management</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">+ New Category</a>
    </div>

    <partial name="_Notification" />

    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Slug</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var parent in Model)
            {
                <tr class="table-secondary">
                    <td class="fw-semibold">
                        @if (parent.SubCategories?.Any() == true)
                        {
                            <span class="text-muted me-1" style="font-size:11px;">▾</span>
                        }
                        @parent.Name
                    </td>
                    <td><span class="badge bg-primary-subtle text-primary-emphasis">Root</span></td>
                    <td><code class="text-muted small">@parent.Slug</code></td>
                    <td class="text-muted small">@(parent.Description ?? "—")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@parent.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@parent.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>

                @if (parent.SubCategories != null)
                {
                    @foreach (var sub in parent.SubCategories)
                    {
                        <tr>
                            <td class="ps-4 text-muted">
                                <span class="border-start border-2 me-2" style="height:14px; display:inline-block;"></span>
                                @sub.Name
                            </td>
                            <td><span class="badge bg-secondary-subtle text-secondary-emphasis">Sub</span></td>
                            <td><code class="text-muted small">@sub.Slug</code></td>
                            <td class="text-muted small">@(sub.Description ?? "—")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>
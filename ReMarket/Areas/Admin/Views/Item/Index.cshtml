@model IEnumerable<Item>
@{
    ViewData["Title"] = "All items";
    var selectedStatus = ViewBag.Status as ItemStatus?;
    int pending = ViewBag.PendingCount ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">All items</h1>
</div>

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Search (name / seller email)</label>
        <input type="search" name="search" value="@ViewBag.Search" class="form-control" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            @foreach (var st in Enum.GetValues<ItemStatus>())
            {
                if (selectedStatus == st)
                {
                    <option value="@st" selected>@st</option>
                }
                else
                {
                    <option value="@st">@st</option>
                }
            }
        </select>
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-primary">Apply</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <p class="text-muted">No items.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th></th>
                    <th>Name</th>
                    <th>Seller</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="" style="width:48px;height:48px;object-fit:cover" class="rounded border" />
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                            <div class="small text-muted"><code>@item.Slug</code></div>
                        </td>
                        <td class="small">@(item.Seller?.Email ?? item.SellerId)</td>
                        <td>@(item.Category?.Name ?? "-")</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>@item.Quantity</td>
                        <td>
                            @switch (item.Status)
                            {
                                case ItemStatus.Pending:
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case ItemStatus.Available:
                                    <span class="badge bg-success">Available</span>
                                    break;
                                case ItemStatus.Rejected:
                                    <span class="badge bg-danger">Rejected</span>
                                    break;
                                case ItemStatus.SoldOut:
                                    <span class="badge bg-secondary">SoldOut</span>
                                    break;
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            @if (item.Status == ItemStatus.Pending)
                            {
                                <form asp-action="Approve" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                                <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Reject</a>
                            }
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@model Category
@using ReMarket.Models
@{
    ViewData["Title"] = Model.Name;
    var items = ViewBag.Items as List<Item> ?? new List<Item>();
}

<partial name="_Notification" />

<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Categories</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-3 mb-3">
    @if (!string.IsNullOrEmpty(Model.IconImagePath))
    {
        <img src="@Model.IconImagePath" alt="@Model.Name" class="rounded border" style="width:64px;height:64px;object-fit:cover" />
    }
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <div class="text-muted small">@(Model.Description ?? "")</div>
    </div>
</div>

@if (Model.SubCategories != null && Model.SubCategories.Any(s => s.IsActive))
{
    <div class="mb-3">
        @foreach (var sub in Model.SubCategories.Where(s => s.IsActive))
        {
            <a asp-action="Detail" asp-route-slug="@sub.Slug" class="badge text-bg-light border me-1 text-decoration-none">@sub.Name</a>
        }
    </div>
}

<form method="get" class="row g-2 mb-4 align-items-end">
    <input type="hidden" name="slug" value="@Model.Slug" />
    <div class="col-md-6">
        <label class="form-label">Search within this category</label>
        <input type="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="Name or description" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Apply</button>
        <a asp-action="Detail" asp-route-slug="@Model.Slug" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!items.Any())
{
    <p class="text-muted">No items match your filters.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in items)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height:180px;object-fit:cover" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">@item.Name</h2>
                        <p class="card-text text-muted small flex-grow-1">@(item.Category?.Name ?? "")</p>
                        <p class="fw-semibold mb-2">@item.Price.ToString("C")</p>
                        <a asp-controller="Item" asp-action="Detail" asp-route-slug="@item.Slug" class="btn btn-outline-primary mt-auto">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

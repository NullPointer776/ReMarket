@using ReMarket.Models
@{
    ViewData["Title"] = "ReMarket";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var latest = ViewBag.LatestItems as List<Item> ?? new List<Item>();
}

<partial name="_Notification" />

<section class="py-4 text-center border-bottom mb-4">
    <h1 class="display-5 fw-semibold">ReMarket</h1>
    <p class="lead text-muted">A second-hand marketplace. Browse items, sell what you no longer need.</p>
    <div class="d-flex justify-content-center gap-2">
        <a asp-area="Buyer" asp-controller="Item" asp-action="Index" class="btn btn-primary">Browse items</a>
        <a asp-area="Buyer" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">All categories</a>
    </div>
</section>

<section class="mb-5">
    <h2 class="h4 mb-3">Categories</h2>
    @if (!categories.Any())
    {
        <p class="text-muted">No categories yet.</p>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var cat in categories)
            {
                <div class="col">
                    <a asp-controller="Category" asp-action="Detail" asp-route-slug="@cat.Slug" class="text-decoration-none text-reset">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(cat.IconImagePath))
                            {
                                <img src="@cat.IconImagePath" class="card-img-top" alt="@cat.Name" style="height:120px;object-fit:cover" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height:120px">
                                    <span class="text-muted">No icon</span>
                                </div>
                            }
                            <div class="card-body">
                                <div class="fw-semibold">@cat.Name</div>
                                <div class="small text-muted">@(cat.Description ?? "")</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0">Latest items</h2>
        <a asp-controller="Item" asp-action="Index" class="small">View all →</a>
    </div>
    @if (!latest.Any())
    {
        <p class="text-muted">No items are available yet.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
            @foreach (var item in latest)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height:160px;object-fit:cover" />
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="fw-semibold">@item.Name</div>
                            <div class="small text-muted flex-grow-1">@(item.Category?.Name ?? "")</div>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="fw-semibold">@item.Price.ToString("C")</span>
                                <a asp-controller="Item" asp-action="Detail" asp-route-slug="@item.Slug" class="btn btn-sm btn-outline-primary">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@{
    ViewData["Title"] = "Home";
}

<section class="hero-card mb-4">
    <span class="hero-chip">Second-hand marketplace</span>
    <h1 class="hero-title mt-3 mb-2">Welcome to ReMarket</h1>
    <p class="hero-subtitle mb-4">
        Browse quality pre-owned items, connect with local sellers, and give products a meaningful second life.
        List your own items in minutes and trade with confidence.
    </p>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary px-4" asp-area="Buyer" asp-controller="Item" asp-action="Index">Browse Items</a>
        <a class="btn btn-outline-primary px-4" asp-area="Seller" asp-controller="Item" asp-action="Create">List an Item</a>
    </div>
</section>

<h2 class="h4 mb-3">Highlights</h2>
<section class="highlight-grid mb-2">
    <article class="highlight-card">
        <h3 class="highlight-title h6">Live listings</h3>
        <p class="mb-0 text-muted">Explore recently posted products from verified local sellers.</p>
    </article>
    <article class="highlight-card">
        <h3 class="highlight-title h6">Safe trade flow</h3>
        <p class="mb-0 text-muted">Review details, inspect conditions, and make purchases with clear item status.</p>
    </article>
    <article class="highlight-card">
        <h3 class="highlight-title h6">Mobile-friendly</h3>
        <p class="mb-0 text-muted">Responsive pages designed for quick browsing on desktop and phone.</p>
    </article>
</section>
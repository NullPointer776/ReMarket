@using ReMarket.Models
@{
    ViewData["Title"] = "ReMarket";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var latest = ViewBag.LatestItems as List<Item> ?? new List<Item>();
}

<partial name="_Notification" />

<section class="py-4 text-center border-bottom mb-4">
    <h1 class="display-5 fw-semibold">ReMarket</h1>
    <p class="lead text-muted">A second-hand marketplace. Browse items, sell what you want to pass value to netx person.</p>
    <div class="d-flex justify-content-center gap-2">
        <a asp-area="Buyer" asp-controller="Item" asp-action="Index" class="btn btn-outline-secondary">All categories</a>
    </div>
</section>
@using System.Globalization
@model ReMarket.Models.ViewModel.ItemDetailViewModel
@{
    ViewData["Title"] = Model.Item.Name;
    var enUs = CultureInfo.GetCultureInfo("en-US");
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="row g-2 item-detail-gallery">
            @if (Model.ImageUrls.Count == 0)
            {
                <div class="col-12">
                    <div class="ratio ratio-1x1 border rounded overflow-hidden bg-light position-relative" style="max-width: 400px;">
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                            <span class="text-muted">No image</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var url in Model.ImageUrls)
                {
                    <div class="col-6 col-lg-3">
                        <div class="ratio ratio-1x1 border rounded overflow-hidden bg-light position-relative">
                            <a href="@url" title="Open image" target="_blank" class="d-block w-100 h-100 position-absolute top-0 start-0">
                                <img src="@url" class="w-100 h-100" alt="@Model.Item.Name" style="object-fit: cover;" />
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
        @if (Model.CanAddMoreImages && !string.IsNullOrEmpty(Model.AddMoreImagesUrl))
        {
            <a href="@Model.AddMoreImagesUrl" class="btn btn-outline-primary btn-sm mt-2">
                <i class="bi bi-plus-lg me-1"></i>Add image
            </a>
            <p class="text-muted small mt-1 mb-0">Up to @ItemGallery.MaxImages images total. You can add more in your listing editor.</p>
        }
    </div>

    <div class="col-md-6">
        <h1 class="h2 mb-3">@Model.Item.Name</h1>

        <div class="mb-3">
            <span class="display-6 text-primary fw-bold">@Model.Item.Price.ToString("C")</span>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Item Details</h5>
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <th style="width: 120px;">Condition:</th>
                        <td>@Model.Item.Condition</td>
                    </tr>
                    <tr>
                        <th>Quantity:</th>
                        <td>
                            @if (Model.Item.Quantity > 0)
                            {
                                <span class="text-success">@Model.Item.Quantity in stock</span>
                            }
                            else
                            {
                                <span class="text-danger">Sold out</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Location:</th>
                        <td>@(string.IsNullOrEmpty(Model.Item.Location) ? "N/A" : Model.Item.Location)</td>
                    </tr>
                    <tr>
                        <th>Category:</th>
                        <td>@(Model.Item.Category?.Name ?? "No category")</td>
                    </tr>
                    <tr>
                        <th>Delivery Option:</th>
                        <td>@Model.Item.DeliveryOption</td>
                    </tr>
                    <tr>
                        <th>Posted:</th>
                        <td>@Model.Item.DatePosted.ToString("MMMM dd, yyyy", enUs)</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Seller Information</h5>
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <th style="width: 120px;">Name:</th>
                        <td>@Model.SellerName</td>
                    </tr>
                    <tr>
                        <th>Email:</th>
                        <td>@Model.SellerEmail</td>
                    </tr>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Item.QrCodeUrl))
        {
            <div class="mb-3">
                <a href="@Model.Item.QrCodeUrl" target="_blank" title="Click to view QR code" class="btn btn-outline-secondary">
                    <i class="bi bi-qr-code me-1"></i>View QR Code
                </a>
            </div>
        }

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Description</h5>
                <p class="card-text">@(string.IsNullOrEmpty(Model.Item.Description) ? "No description provided." : Model.Item.Description)</p>
            </div>
        </div>

        <div class="d-grid gap-2">
            @if (Model.Item.Quantity > 0 && Model.Item.Status == ItemStatus.Available)
            {
                <a asp-action="Buy" asp-route-slug="@Model.Item.Slug" class="btn btn-primary btn-lg">
                    <i class="bi bi-cart-plus me-2"></i>Buy Now
                </a>
            }
            else
            {
                <button class="btn btn-secondary btn-lg" disabled>Sold Out</button>
            }
        </div>
    </div>
</div>

<p class="mt-4">
    <a asp-action="Index" class="btn btn-link">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</p>

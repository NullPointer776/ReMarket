@model Item
@{
    ViewData["Title"] = "List an item";
}

<h1 class="h3 mb-3">List an item for sale</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" type="number" min="1" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Condition" class="form-label"></label>
        <select asp-for="Condition" asp-items="Html.GetEnumSelectList<Condition>()" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="DeliveryOption" class="form-label"></label>
        <select asp-for="DeliveryOption" asp-items="Html.GetEnumSelectList<DeliveryOption>()" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
            <option value="">Select a category</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" for="imageFileInput">Item images (1 to @ItemGallery.MaxImages)</label>
        <input id="imageFileInput" name="imageFiles" type="file" class="form-control" accept="image/*" multiple
               data-val="true" data-val-required="Please select at least one image." />
        <span class="text-danger" data-valmsg-for="imageFiles" data-valmsg-replace="true"></span>
        <div class="form-text">jpg / png / gif / webp, max 5 MB each. First image is the cover on listings.</div>
        <div class="mt-2 d-flex flex-wrap gap-2" id="imagePreviewRow"></div>
    </div>

    <button type="submit" class="btn btn-primary">Submit for review</button>
    <a asp-action="Index" class="btn btn-link">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $.validator.unobtrusive.parse(document);
        });
        document.getElementById('imageFileInput')?.addEventListener('change', function (e) {
            const row = document.getElementById('imagePreviewRow');
            if (!row) return;
            row.innerHTML = '';
            const files = e.target.files;
            if (!files || !files.length) return;
            for (let i = 0; i < files.length; i++) {
                const f = files[i];
                if (!f.type.startsWith('image/')) continue;
                const r = new FileReader();
                r.onload = function (ev) {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.className = 'img-thumbnail';
                    img.style.maxHeight = '100px';
                    row.appendChild(img);
                };
                r.readAsDataURL(f);
            }
        });
    </script>
}
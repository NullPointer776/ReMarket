@model Item
@{
    ViewData["Title"] = "Edit item";
}


<h1 class="h3 mb-3">Edit item</h1>
<p class="text-muted small">Current status: <strong>@Model.Status</strong>. If the item was rejected, saving will send it back to pending review.</p>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" required />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" type="number" min="0" required />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Condition" class="form-label"></label>
        <select asp-for="Condition" asp-items="Html.GetEnumSelectList<Condition>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="DeliveryOption" class="form-label"></label>
        <select asp-for="DeliveryOption" asp-items="Html.GetEnumSelectList<DeliveryOption>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select" required></select>
    </div>
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="mb-2">
            <span class="form-label d-block">Current image</span>
            <img src="@Model.ImageUrl" alt="" class="img-thumbnail" style="max-height:200px" />
        </div>
    }
    <div class="mb-3">
        <label class="form-label" for="imageFileInput">Replace image (optional)</label>
        <input id="imageFileInput" name="imageFile" type="file" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp,.jpg,.jpeg,.png,.gif,.webp" capture="environment" />
        <span class="text-danger d-block">@Html.ValidationMessage("imageFile")</span>
        <div class="form-text">Leave empty to keep the current image. Max 5 MB.</div>
        <div class="mt-2">
            <img id="newImagePreview" src="" alt="New preview" class="img-thumbnail d-none" style="max-height:220px" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imageFileInput')?.addEventListener('change', function (e) {
            const f = e.target.files && e.target.files[0];
            const prev = document.getElementById('newImagePreview');
            if (!f || !prev) return;
            const r = new FileReader();
            r.onload = function (ev) {
                prev.src = ev.target.result;
                prev.classList.remove('d-none');
            };
            r.readAsDataURL(f);
        });
    </script>
}

@model IEnumerable<Item>
@{
    ViewData["Title"] = "我的商品";
}

<partial name="_Notification" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">我的商品</h1>
    <a asp-action="Create" class="btn btn-primary">发布商品</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">暂无商品，点击「发布商品」开始出售。</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>名称</th>
                    <th>分类</th>
                    <th>价格</th>
                    <th>状态</th>
                    <th>发布于</th>
                    <th>二维码</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(item.Category?.Name ?? "-")</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>@item.Status</td>
                        <td>@item.DatePosted.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.QrCodeUrl))
                            {
                                <img src="@item.QrCodeUrl" alt="QR" width="64" height="64" class="border rounded" />
                            }
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Preview" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">预览</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">编辑</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">删除</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

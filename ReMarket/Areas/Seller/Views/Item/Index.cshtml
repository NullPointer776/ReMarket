@model IEnumerable<Item>
@{
    ViewData["Title"] = "My items";
}

<partial name="_Notification" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">My items</h1>
    <a asp-action="Create" class="btn btn-primary">List an item</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No items yet. Click &quot;List an item&quot; to get started.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Posted</th>
                    <th>QR</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(item.Category?.Name ?? "-")</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>@item.Status</td>
                        <td>@item.DatePosted.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.QrCodeUrl))
                            {
                                <a href="@item.QrCodeUrl" target="_blank">
                                <img src="@item.QrCodeUrl" alt="QR" width="64" height="64" class="border rounded" />
                                </a>
                            }
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Preview" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Preview</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
